# このファイルをコピーして .env を作り、自分のキーを記入してください
#   cp .env.example .env
# .env は .gitignore 済みなので公開されません

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- AmiVoice API（使っている場合のみ） ---
AMIVOICE_APP_KEY=xxxxxxxxxxxxxxxxxxxx

# --- 動作設定（例。実装に合わせて増減） ---
DEFAULT_CONVERSATION_LEVEL=1
TTS_VOICE=alloy
LOG_DIR=./logs
